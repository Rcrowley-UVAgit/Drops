# ============================================
# DROPS V1 — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Supabase (get from supabase.com → Project Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Spotify credentials go in SUPABASE EDGE FUNCTION SECRETS — not here.
# Store them via: Supabase Dashboard → Edge Functions → Secrets
#   SPOTIFY_CLIENT_ID=your-client-id
#   SPOTIFY_CLIENT_SECRET=your-client-secret
